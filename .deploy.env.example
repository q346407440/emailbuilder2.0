# 本地/服务器通用部署变量示例
# 使用方式：
# 1. 复制为 .deploy.env
# 2. 按你的环境修改
# 3. 脚本会优先读取当前目录或脚本同目录上两级的 .deploy.env

# ========== 本地发布到服务器 ==========
SERVER_HOST=root@111.230.53.224
SERVER_PROJECT_DIR=/root/emailbuilder2.0
# LOCAL_PROJECT_DIR=/path/to/your/local/project
KEEP_LOCAL_ARCHIVES=0
REMOTE_TMP_DIR=/root/.deploy-tmp

# ========== 服务器导出交付包 ==========
OUT_BASE=/root
KEEP_ARCHIVES=1

# ========== Git ==========
GIT_REMOTE=origin
GIT_BRANCH=main

# ========== 其他 ==========
DEPLOY_DIST_DIR=/var/www/emailbuilder2.0
